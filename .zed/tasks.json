[
  {
    "label": "Meson: Setup Build",
    "command": "meson setup build --prefix=$ZED_WORKTREE_ROOT/install",
    "cwd": "$ZED_WORKTREE_ROOT",
    "shell": "system",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Meson: Wipe Build",
    "command": "meson setup",
    "args": ["--wipe", "build", "--prefix=$ZED_WORKTREE_ROOT/install"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "shell": "system",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Meson: Build All",
    "command": "meson compile",
    "args": ["-C", "build"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "shell": "system",
    "reveal": "always",
    "hide": "on_success",
    "allow_concurrent_runs": false,
  },
  {
    "label": "Meson: Build CLI Only",
    "command": "meson compile",
    "args": ["-C", "build", "orbital"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "shell": "system",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Meson: Build GUI Only",
    "command": "meson compile",
    "args": ["-C", "build", "orbital-gui"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "shell": "system",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Meson: Build Tests",
    "command": "meson compile",
    "args": [
      "-C",
      "build",
      "test_gamelibrary",
      "test_envvarschema",
      "test_presetmerge",
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "shell": "system",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Meson: Run Tests",
    "command": "meson test",
    "args": ["-C", "build"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "shell": "system",
    "reveal": "always",
    "hide": "on_success",
  },
  {
    "label": "Meson: Clean Build",
    "command": "meson compile",
    "args": ["--clean", "-C", "build"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "shell": "system",
    "reveal": "always",
    "hide": "on_success",
  },
]
